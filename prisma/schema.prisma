generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SECRETARY
}

enum SiteStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Profile {
  id        String   @id
  email     String   @unique
  name      String
  role      Role     @default(SECRETARY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkSite {
  id            String        @id @default(cuid())
  name          String
  location      String?
  description   String?
  clientName    String?
  clientPhone   String?
  contractValue Float?
  status        SiteStatus    @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
}

model Transaction {
  id          String          @id @default(cuid())
  workSiteId  String
  workSite    WorkSite        @relation(fields: [workSiteId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Float
  description String
  category    String?
  date        DateTime        @default(now())
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum EquipmentType {
  TRUCK
  MINI_EXCAVATOR
  BOBCAT
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  IN_REPAIR
  INACTIVE
}

enum DocumentType {
  LICENSE
  INSURANCE
  PERMIT
  CONTRACT
  RECEIPT
  OTHER
}

model Equipment {
  id           String             @id @default(cuid())
  name         String
  type         EquipmentType
  licensePlate String?
  year         Int?
  description  String?
  status       EquipmentStatus    @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  maintenance  MaintenanceRecord[]
  insurances   Insurance[]
  expenses     EquipmentExpense[]
  documents    Document[]
}

model MaintenanceRecord {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  description String
  cost        Float?
  date        DateTime  @default(now())
  mileage     Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Insurance {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  type         String
  company      String?
  policyNumber String?
  startDate    DateTime
  endDate      DateTime
  cost         Float
  isPaid       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EquipmentExpense {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  description String
  date        DateTime  @default(now())
  receiptUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Document {
  id          String       @id @default(cuid())
  title       String
  type        DocumentType
  fileUrl     String?
  expiryDate  DateTime?
  notes       String?
  equipmentId String?
  equipment   Equipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  to        String
  toName    String?
  body      String
  status    String   @default("sent")
  siteId    String?
  sentBy    String?
  createdAt DateTime @default(now())
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assignedTo  String?
  siteId      String?
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
