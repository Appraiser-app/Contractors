generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SECRETARY
}

enum UserRole {
  GC
  SUB
  COMMUNITY
}

enum BidStatus {
  PENDING
  REVIEWED
  AWARDED
  DECLINED
}

enum SiteStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Profile {
  id                  String    @id
  email               String    @unique
  name                String
  role                Role      @default(SECRETARY)
  googleRefreshToken  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // BuildersBooks social profile fields
  userRole            UserRole  @default(COMMUNITY)
  zipCode             String?
  trade               String?
  bio                 String?
  avatarUrl           String?
  phone               String?
  businessName        String?
  website             String?
  serviceRadius       Int       @default(25)
  language            String    @default("en")
  isVerified          Boolean   @default(false)
  rating              Float     @default(0)
  ratingCount         Int       @default(0)
}

model WorkSite {
  id            String        @id @default(cuid())
  name          String
  location      String?
  description   String?
  clientName    String?
  clientPhone   String?
  contractValue Float?
  status        SiteStatus    @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
  budgetAreas   ProjectBudgetArea[]
}

model ProjectBudgetArea {
  id           String   @id @default(cuid())
  siteId       String
  site         WorkSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name         String
  budgetAmount Float    @default(0)
  notes        String?
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Transaction {
  id             String          @id @default(cuid())
  workSiteId     String
  workSite       WorkSite        @relation(fields: [workSiteId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Float
  description    String
  category       String?
  date           DateTime        @default(now())
  receiptUrl     String?
  approvalStatus ApprovalStatus  @default(PENDING)
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum EquipmentType {
  TRUCK
  MINI_EXCAVATOR
  BOBCAT
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  IN_REPAIR
  INACTIVE
}

enum DocumentType {
  LICENSE
  INSURANCE
  PERMIT
  CONTRACT
  RECEIPT
  OTHER
}

model Equipment {
  id           String             @id @default(cuid())
  name         String
  type         EquipmentType
  licensePlate String?
  year         Int?
  description  String?
  status       EquipmentStatus    @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  maintenance  MaintenanceRecord[]
  insurances   Insurance[]
  expenses     EquipmentExpense[]
  documents    Document[]
}

model MaintenanceRecord {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  description String
  cost        Float?
  date        DateTime  @default(now())
  mileage     Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Insurance {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  type         String
  company      String?
  policyNumber String?
  startDate    DateTime
  endDate      DateTime
  cost         Float
  isPaid       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EquipmentExpense {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  description String
  date        DateTime  @default(now())
  receiptUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Document {
  id          String       @id @default(cuid())
  title       String
  type        DocumentType
  fileUrl     String?
  expiryDate  DateTime?
  notes       String?
  equipmentId String?
  equipment   Equipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  to        String
  toName    String?
  body      String
  status    String   @default("sent")
  siteId    String?
  sentBy    String?
  createdAt DateTime @default(now())
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assignedTo  String?
  siteId      String?
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// =============================================
// BuildersBooks Social Network Models
// =============================================

model Post {
  id         String        @id @default(cuid())
  authorId   String
  content    String?
  imageUrls  String[]
  trade      String?
  zipCode    String?
  likesCount Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  likes      PostLike[]
  comments   PostComment[]
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  createdAt DateTime @default(now())
}

model PublicProject {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  description String?
  trade       String
  zipCode     String
  budget      Float?
  timeline    String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bids        Bid[]
}

model Bid {
  id           String        @id @default(cuid())
  projectId    String
  project      PublicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bidderId     String
  price        Float
  availability String?
  notes        String?
  status       BidStatus     @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Conversation {
  id            String    @id @default(cuid())
  participant1  String
  participant2  String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  messages      Message[]
  @@unique([participant1, participant2])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  projectId  String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}
